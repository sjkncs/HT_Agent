          },
          "success": true
        }
      }
    },
    {
      "name": "previewOrder",
      "category": "订单",
      "description": "喜茶订单预览 — 显示商品明细、价格计算、优惠券匹配、预计取餐时间",
      "luckinEquivalent": "previewOrder",
      "inputSchema": {
        "type": "object",
        "properties": {
          "storeId": { "type": "integer", "required": true, "description": "门店ID" },
          "productList": {
            "type": "array",
            "required": true,
            "description": "商品列表",
            "items": {
              "type": "object",
              "properties": {
                "amount": { "type": "integer", "required": true, "description": "数量" },
                "productId": { "type": "integer", "required": true, "description": "商品ID" },
                "skuCode": { "type": "string", "required": true, "description": "SKU编码" }
              }
            }
          },
          "pickupType": {
            "type": "string",
            "required": false,
            "enum": ["self_pickup", "delivery"],
            "description": "取餐方式：self_pickup=到店自取, delivery=外卖配送"
          }
        },
        "required": ["storeId", "productList"]
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "code": { "type": "number" },
          "msg": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "aboutTime": { "type": "number", "description": "预计取餐/送达时间戳(ms)" },
              "estimatedWaitMinutes": { "type": "number", "description": "预计等待分钟数" },
              "discountPrice": { "type": "number", "description": "实付金额" },
              "totalInitialPrice": { "type": "number", "description": "商品总面价" },
              "privilegeMoney": { "type": "number", "description": "优惠金额" },
              "deliveryFee": { "type": "number", "description": "配送费（外卖时）" },
              "pickupType": { "type": "string", "description": "取餐方式" },
              "storeInfo": {
                "type": "object",
                "properties": {
                  "storeId": { "type": "number" },
                  "storeName": { "type": "string" },
                  "address": { "type": "string" }
                }
              },
              "productInfoList": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "productId": { "type": "number" },
                    "skuCode": { "type": "string" },
                    "name": { "type": "string" },
                    "amount": { "type": "number" },
                    "additionDesc": { "type": "string", "description": "属性描述，如「五分糖/少冰/加芝士」" },
                    "breviaryPicUrl": { "type": "string" },
                    "initPrice": { "type": "number" },
                    "estimatePrice": { "type": "number" },
                    "estimateTotalPrice": { "type": "number" }
                  }
                }
              },
              "couponCodeList": { "type": "array", "items": { "type": "string" } }
            }
          },
          "success": { "type": "boolean" }
        }
      },
      "example": {
        "request": {
          "storeId": 10086,
          "productList": [
            { "amount": 1, "productId": 2001, "skuCode": "HT-2001-003" }
          ],
          "pickupType": "self_pickup"
        },
        "response": {
          "code": 0,
          "msg": "success",
          "data": {
            "aboutTime": 1718000400000,
            "estimatedWaitMinutes": 12,
            "discountPrice": 29,
            "totalInitialPrice": 29,
            "privilegeMoney": 0,
            "deliveryFee": 0,
            "pickupType": "self_pickup",
            "storeInfo": {
              "storeId": 10086,
              "storeName": "喜茶·深圳万象天地店",
              "address": "深圳市南山区深南大道9668号"
            },
            "productInfoList": [
              {
                "productId": 2001,
                "skuCode": "HT-2001-003",
                "name": "多肉葡萄",
                "amount": 1,
                "additionDesc": "五分糖/正常冰",
                "breviaryPicUrl": "https://cdn.heytea.com/products/multigrape_s.jpg",
                "initPrice": 29,
                "estimatePrice": 29,
                "estimateTotalPrice": 29
              }
            ],
            "couponCodeList": []
          },
          "success": true
        }
      }
    },
    {
      "name": "createOrder",
      "category": "订单",
      "description": "喜茶创建订单 — 返回微信支付链接和二维码，支持自取/外卖",
      "luckinEquivalent": "createOrder",
      "inputSchema": {
        "type": "object",
        "properties": {
          "storeId": { "type": "integer", "required": true },
          "productList": { "type": "array", "required": true, "description": "商品列表（同previewOrder）" },
          "longitude": { "type": "number", "required": true, "description": "用户经度" },
          "latitude": { "type": "number", "required": true, "description": "用户纬度" },
          "couponCodeList": { "type": "array", "items": { "type": "string" }, "required": false },
          "pickupType": { "type": "string", "enum": ["self_pickup", "delivery"], "required": false },
          "remark": { "type": "string", "required": false, "description": "订单备注，如「少放冰」「多加糖」" }
        },
        "required": ["storeId", "productList", "longitude", "latitude"]
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "code": { "type": "number" },
          "msg": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "orderId": { "type": "number" },
              "orderIdStr": { "type": "string" },
              "storeInfo": { "type": "object", "description": "门店信息", "properties": { "storeId": { "type": "number" }, "storeName": { "type": "string" }, "address": { "type": "string" } } },
              "payOrderUrl": { "type": "string", "description": "微信支付URL" },
              "payOrderQrCodeUrl": { "type": "string", "description": "支付二维码链接" },
              "discountPrice": { "type": "number", "description": "实付金额" },
              "needPay": { "type": "boolean", "description": "是否需要支付" },
              "tradeNo": { "type": ["string", "null"] },
              "description": { "type": ["string", "null"] }
            }
          },
          "success": { "type": "boolean" }
        }
      },
      "example": {
        "request": {
          "storeId": 10086,
          "productList": [{ "amount": 1, "productId": 2001, "skuCode": "HT-2001-003" }],
          "longitude": 113.94441,
          "latitude": 22.52736,
