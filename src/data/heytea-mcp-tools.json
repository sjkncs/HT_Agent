{
  "name": "heytea-mcp-tools",
  "version": "1.0.0",
  "description": "喜茶自助点单 MCP 工具定义 — 对标瑞幸咖啡 MCP 8 工具模式，适配茶饮生态",
  "protocol": {
    "type": "streamablehttp",
    "version": "2024-11-05",
    "transport": "Streamable HTTP",
    "encoding": "JSON-RPC 2.0"
  },
  "server": {
    "url": "https://mcp.heytea.com/api/v1/mcp",
    "auth": {
      "type": "Bearer",
      "header": "Authorization",
      "format": "Bearer {token}"
    },
    "mcpServerConfig": {
      "mcpServers": {
        "heytea-order": {
          "type": "streamablehttp",
          "url": "https://mcp.heytea.com/api/v1/mcp",
          "headers": {
            "Authorization": "Bearer {YOUR_HEYTEA_MCP_TOKEN}"
          }
        }
      }
    }
  },
  "tools": [
    {
      "name": "queryStoreList",
      "category": "门店",
      "description": "喜茶查询门店列表 — 根据地理位置查询附近喜茶门店，支持按名称搜索",
      "luckinEquivalent": "queryShopList",
      "inputSchema": {
        "type": "object",
        "properties": {
          "storeName": {
            "type": "string",
            "required": false,
            "description": "门店名称关键词，用于模糊搜索"
          },
          "longitude": {
            "type": "number",
            "required": true,
            "description": "用户经度，如 113.94441"
          },
          "latitude": {
            "type": "number",
            "required": true,
            "description": "用户纬度，如 22.52736"
          }
        },
        "required": ["longitude", "latitude"]
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "code": { "type": "number", "description": "状态码，0=成功" },
          "msg": { "type": "string" },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "storeId": { "type": "number", "description": "门店ID" },
                "storeName": { "type": "string", "description": "门店名称" },
                "address": { "type": "string", "description": "门店地址" },
                "storeTags": { "type": "array", "items": { "type": "string" }, "description": "门店标签：堂食/外卖/24h/新店" },
                "longitude": { "type": "number" },
                "latitude": { "type": "number" },
                "workTimeStart": { "type": "string", "description": "营业开始时间，如 08:00" },
                "workTimeEnd": { "type": "string", "description": "营业结束时间，如 22:00" },
                "businessStatus": { "type": "number", "description": "营业状态：1=营业中, 2=休息中, 3=即将打烊" },
                "distance": { "type": "number", "description": "距离，单位千米" },
                "storeNo": { "type": "string", "description": "门店编号" },
                "phone": { "type": "string", "description": "门店电话" }
              }
            }
          },
          "success": { "type": "boolean" }
        }
      },
      "example": {
        "request": {
          "storeName": "",
          "longitude": 113.94441,
          "latitude": 22.52736
        },
        "response": {
          "code": 0,
          "msg": "success",
          "data": [
            {
              "storeId": 10086,
              "storeName": "喜茶·深圳万象天地店",
              "address": "深圳市南山区深南大道9668号万象天地LG层",
              "storeTags": ["堂食", "外卖"],
              "longitude": 113.94512,
              "latitude": 22.52891,
              "workTimeStart": "10:00",
              "workTimeEnd": "22:00",
              "businessStatus": 1,
              "distance": 0.23,
              "storeNo": "SZ-0086",
              "phone": "0755-88886666"
            }
          ],
          "success": true
        }
      }
    },
    {
      "name": "searchProduct",
      "category": "商品",
      "description": "喜茶根据用户 query 匹配商品推荐结果 — 支持品类搜索、关键词搜索、热门推荐",
      "luckinEquivalent": "searchProductForMcp",
      "inputSchema": {
        "type": "object",
        "properties": {
          "storeId": {
            "type": "integer",
            "required": true,
            "description": "门店ID"
          },
          "query": {
            "type": "string",
            "required": true,
            "description": "用户原始查询文本，如「多肉葡萄」「有什么新品」「果茶推荐」"
          }
        },
        "required": ["storeId", "query"]
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "code": { "type": "number" },
          "msg": { "type": "string" },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "productId": { "type": "number", "description": "商品ID" },
                "productName": { "type": "string", "description": "商品名称" },
                "skuCode": { "type": "string", "description": "商品SKU编码" },
                "pictureUrl": { "type": "string", "description": "商品图片URL" },
                "category": { "type": "string", "description": "商品分类：芝芝系列/多肉系列/纯茶/果茶/季节限定/小食" },
                "description": { "type": "string", "description": "商品描述" },
                "productAttrs": {
                  "type": "array",
                  "description": "商品属性列表",
                  "items": {
                    "type": "object",
                    "properties": {
                      "attributeId": { "type": "number", "description": "属性组ID (1=糖度,2=冰量,3=加料,4=杯型)" },
                      "attributeName": { "type": "string", "description": "属性组名称" },
                      "multiSelect": { "type": "boolean", "description": "是否可多选（加料支持多选）" },
                      "productSubAttrs": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "attributeId": { "type": "number" },
                            "attributeName": { "type": "string" },
                            "selected": { "type": ["boolean", "null"] },
                            "price": { "type": "number", "description": "属性加价" },
                            "canSelected": { "type": ["number", "null"] }
                          }
                        }
                      }
                    }
                  }
                },
                "tags": { "type": "array", "items": { "type": "string" }, "description": "商品标签：新品/热销/限定" },
                "initialPrice": { "type": "number", "description": "面价（元）" },
                "estimatePrice": { "type": "number", "description": "预估到手价（元）" }
              }
            }
          },
          "success": { "type": "boolean" }
        }
      },
      "example": {
        "request": {
          "storeId": 10086,
          "query": "多肉葡萄"
        },
        "response": {
          "code": 0,
          "msg": "success",
          "data": [
            {
              "productId": 2001,
              "productName": "多肉葡萄",
              "skuCode": "HT-2001-001",
              "pictureUrl": "https://cdn.heytea.com/products/multigrape.jpg",
              "category": "多肉系列",
              "description": "手剥巨峰葡萄搭配清新茶底，果肉满满",
              "productAttrs": [
                {
                  "attributeId": 1,
                  "attributeName": "糖度",
                  "multiSelect": false,
                  "productSubAttrs": [
                    { "attributeId": 101, "attributeName": "全糖", "selected": null, "price": 0 },
                    { "attributeId": 102, "attributeName": "七分糖", "selected": null, "price": 0 },
                    { "attributeId": 103, "attributeName": "五分糖", "selected": null, "price": 0 },
                    { "attributeId": 104, "attributeName": "三分糖", "selected": null, "price": 0 },
                    { "attributeId": 105, "attributeName": "无糖", "selected": null, "price": 0 }
                  ]
                },
                {
                  "attributeId": 2,
                  "attributeName": "冰量",
                  "multiSelect": false,
                  "productSubAttrs": [
                    { "attributeId": 201, "attributeName": "正常冰", "selected": null, "price": 0 },
                    { "attributeId": 202, "attributeName": "少冰", "selected": null, "price": 0 },
                    { "attributeId": 203, "attributeName": "去冰", "selected": null, "price": 0 },
                    { "attributeId": 204, "attributeName": "温", "selected": null, "price": 0 },
                    { "attributeId": 205, "attributeName": "热", "selected": null, "price": 0 }
                  ]
                },
                {
                  "attributeId": 3,
                  "attributeName": "加料",
                  "multiSelect": true,
                  "productSubAttrs": [
                    { "attributeId": 301, "attributeName": "芝士", "selected": null, "price": 3 },
                    { "attributeId": 302, "attributeName": "椰果", "selected": null, "price": 2 },
                    { "attributeId": 303, "attributeName": "珍珠", "selected": null, "price": 2 },
                    { "attributeId": 304, "attributeName": "芋圆", "selected": null, "price": 3 },
                    { "attributeId": 305, "attributeName": "红豆", "selected": null, "price": 2 },
                    { "attributeId": 306, "attributeName": "芦荟", "selected": null, "price": 2 }
                  ]
                },
                {
                  "attributeId": 4,
                  "attributeName": "杯型",
                  "multiSelect": false,
                  "productSubAttrs": [
                    { "attributeId": 401, "attributeName": "中杯", "selected": null, "price": 0 },
                    { "attributeId": 402, "attributeName": "大杯", "selected": null, "price": 3 }
                  ]
                }
              ],
              "tags": ["热销", "经典"],
              "initialPrice": 29,
              "estimatePrice": 29
            }
          ],
          "success": true
        }
      }
    },
    {
      "name": "customizeProduct",
      "category": "商品",
      "description": "喜茶商品属性定制切换 — 支持糖度/冰量/加料（多选）/杯型的组合定制",
      "luckinEquivalent": "switchProduct",
      "inputSchema": {
        "type": "object",
        "properties": {
          "storeId": { "type": "integer", "required": true, "description": "门店ID" },
          "productId": { "type": "integer", "required": true, "description": "商品ID" },
          "skuCode": { "type": "string", "required": true, "description": "商品SKU编码" },
          "attrOperationParam": {
            "type": "object",
            "required": true,
            "description": "属性切换参数",
            "properties": {
              "attributeId": { "type": "integer", "description": "属性组ID (1=糖度,2=冰量,3=加料,4=杯型)" },
              "subAttr": {
                "type": "object",
                "properties": {
                  "attributeId": { "type": "integer", "description": "属性值ID" },
                  "operation": { "type": "integer", "description": "操作类型：3=选中, 1=取消（加料多选时使用取消）" }
                }
              }
            }
          },
          "amount": { "type": "integer", "required": true, "description": "商品数量" }
        },
        "required": ["storeId", "productId", "skuCode", "attrOperationParam", "amount"]
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "code": { "type": "number" },
          "msg": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "productId": { "type": "number" },
              "productName": { "type": "string" },
              "skuCode": { "type": "string", "description": "切换后的SKU编码" },
              "pictureUrl": { "type": "string" },
              "productAttrs": { "type": "array", "description": "切换后的属性状态" },
              "tags": { "type": "array" },
              "initialPrice": { "type": "number", "description": "更新后的面价" },
              "estimatePrice": { "type": "number", "description": "更新后的预估到手价" }
            }
          },
          "success": { "type": "boolean" }
        }
      },
      "example": {
        "request": {
          "storeId": 10086,
          "productId": 2001,
          "skuCode": "HT-2001-001",
          "attrOperationParam": {
            "attributeId": 1,
            "subAttr": {
              "attributeId": 103,
              "operation": 3
            }
          },
          "amount": 1
        },
        "response": {
          "code": 0,
          "msg": "success",
          "data": {
            "productId": 2001,
            "productName": "多肉葡萄",
            "skuCode": "HT-2001-003",
            "pictureUrl": "https://cdn.heytea.com/products/multigrape.jpg",
            "productAttrs": [
              {
                "attributeId": 1,
                "attributeName": "糖度",
                "productSubAttrs": [
                  { "attributeId": 101, "attributeName": "全糖", "selected": false, "price": 0, "canSelected": 1 },
                  { "attributeId": 102, "attributeName": "七分糖", "selected": false, "price": 0, "canSelected": 1 },
                  { "attributeId": 103, "attributeName": "五分糖", "selected": true, "price": 0, "canSelected": 1 },
                  { "attributeId": 104, "attributeName": "三分糖", "selected": false, "price": 0, "canSelected": 1 },
                  { "attributeId": 105, "attributeName": "无糖", "selected": false, "price": 0, "canSelected": 1 }
                ]
              }
            ],
            "tags": ["热销"],
            "initialPrice": 29,
            "estimatePrice": 29
          },
          "success": true
        }
      }
    },
    {
      "name": "queryProductDetail",
      "category": "商品",
      "description": "喜茶查询商品详情 — 包含完整属性选项、原料成分、过敏原、营养信息",
      "luckinEquivalent": "queryProductDetailInfo",
      "inputSchema": {
        "type": "object",
        "properties": {
          "storeId": { "type": "integer", "required": true, "description": "门店ID" },
          "productId": { "type": "integer", "required": true, "description": "商品ID" }
        },
        "required": ["storeId", "productId"]
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "code": { "type": "number" },
          "msg": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "productId": { "type": "number" },
              "productName": { "type": "string" },
              "skuCode": { "type": "string" },
              "pictureUrl": { "type": "string" },
              "category": { "type": "string" },
              "description": { "type": "string", "description": "商品描述" },
              "ingredients": { "type": "array", "items": { "type": "string" }, "description": "原料成分" },
              "allergens": { "type": "array", "items": { "type": "string" }, "description": "过敏原信息" },
              "nutritionInfo": {
                "type": "object",
                "description": "营养信息",
                "properties": {
                  "calories": { "type": "string", "description": "热量" },
                  "sugar": { "type": "string", "description": "含糖量" },
                  "caffeine": { "type": "string", "description": "咖啡因含量" }
                }
              },
              "productAttrs": { "type": "array", "description": "商品属性列表" },
              "tags": { "type": "array" },
              "initialPrice": { "type": "number" },
              "estimatePrice": { "type": "number" }
            }
          },
          "success": { "type": "boolean" }
        }
      },
      "example": {
